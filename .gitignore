# Python bytecode and interpreter caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python packaging and build outputs
build/
dist/
artifacts/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Test, coverage, lint and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache/

# Runtime logs and generated local diagnostics
logs/*
*.log
!logs/.gitkeep

# Local secrets, credentials and machine-specific config
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/
private/
credentials/
data/secrets/
data/private/
config.local.json
data/config.local.json
data/settings.local.json

# Editor and OS noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/tasks.json
!.vscode/extensions.json

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo

# Windows and PyInstaller generated distributables
*.exe
*.msi
*.manifest
